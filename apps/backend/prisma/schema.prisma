  userBooks       UserBook[]

  @@index([title])
  @@index([releaseYear])
  @@index([country])
  @@index([format])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([status, releaseYear])
  @@index([language, country])
  @@map("books")
}

model Game {
