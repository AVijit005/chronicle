  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User     @relation("NotificationPreferenceUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([updatedAt])
  @@map("notification_preferences")
}

model ActivityFeed {
  id          String          @id @default(uuid()) @map("id") @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  type        ActivityType    @map("type")
  title       String          @map("title")
  description String?         @map("description")
  icon        String?         @map("icon")
  color       String?         @map("color")
  visibility  VisibilityLevel @default(PRIVATE) @map("visibility")
  metadata    Json?           @map("metadata")
  createdAt   DateTime        @default(now()) @map("created_at")
  user        User            @relation("ActivityFeedUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([type])
  @@index([userId, createdAt])
  @@index([userId, type])
  @@map("activity_feed")
}

model Recommendation {
  id           String               @id @default(uuid()) @map("id") @db.Uuid
  userId       String               @map("user_id") @db.Uuid
  reason       RecommendationReason @map("reason")
  score        Float?               @map("score")
  movieId      String?              @map("movie_id") @db.Uuid
  tvShowId     String?              @map("tv_show_id") @db.Uuid
  animeId      String?              @map("anime_id") @db.Uuid
  bookId       String?              @map("book_id") @db.Uuid
  gameId       String?              @map("game_id") @db.Uuid
  musicAlbumId String?              @map("music_album_id") @db.Uuid
  podcastId    String?              @map("podcast_id") @db.Uuid
  courseId     String?              @map("course_id") @db.Uuid
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  anime        Anime?               @relation("RecommendationAnime", fields: [animeId], references: [id], onDelete: Cascade)
  book         Book?                @relation("RecommendationBook", fields: [bookId], references: [id], onDelete: Cascade)
  course       Course?              @relation("RecommendationCourse", fields: [courseId], references: [id], onDelete: Cascade)
  game         Game?                @relation("RecommendationGame", fields: [gameId], references: [id], onDelete: Cascade)
  movie        Movie?               @relation("RecommendationMovie", fields: [movieId], references: [id], onDelete: Cascade)
  musicAlbum   MusicAlbum?          @relation("RecommendationMusicAlbum", fields: [musicAlbumId], references: [id], onDelete: Cascade)
  podcast      Podcast?             @relation("RecommendationPodcast", fields: [podcastId], references: [id], onDelete: Cascade)
  tvShow       TvShow?              @relation("RecommendationTvShow", fields: [tvShowId], references: [id], onDelete: Cascade)
  user         User                 @relation("RecommendationUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@unique([userId, tvShowId])
  @@unique([userId, animeId])
  @@unique([userId, bookId])
  @@unique([userId, gameId])
  @@unique([userId, musicAlbumId])
  @@unique([userId, podcastId])
  @@unique([userId, courseId])
  @@index([movieId])
  @@index([tvShowId])
  @@index([animeId])
  @@index([bookId])
  @@index([gameId])
  @@index([musicAlbumId])
  @@index([podcastId])
  @@index([courseId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([score])
  @@index([userId, createdAt])
  @@map("recommendations")
}

model WrappedYear {
  id          String        @id @default(uuid()) @map("id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  year        Int           @map("year")
  coverImage  String?       @map("cover_image")
  generatedAt DateTime      @default(now()) @map("generated_at")
  metadata    Json?         @map("metadata")
  stats       WrappedStat[] @relation("WrappedYearStats")
  user        User          @relation("WrappedYearUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
  @@index([year])
  @@index([generatedAt])
  @@map("wrapped_years")
}

model WrappedStat {
  id            String      @id @default(uuid()) @map("id") @db.Uuid
  wrappedYearId String      @map("wrapped_year_id") @db.Uuid
  title         String      @map("title")
  value         String      @map("value")
  icon          String?     @map("icon")
  sortOrder     Int         @default(0) @map("sort_order")
  wrappedYear   WrappedYear @relation("WrappedYearStats", fields: [wrappedYearId], references: [id], onDelete: Cascade)

  @@index([sortOrder])
  @@index([wrappedYearId, sortOrder])
  @@map("wrapped_stats")
}

model AnalyticsSnapshot {
  id               String   @id @default(uuid()) @map("id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  snapshotDate     DateTime @map("snapshot_date") @db.Date
  moviesCompleted  Int      @default(0) @map("movies_completed")
  episodesWatched  Int      @default(0) @map("episodes_watched")
  booksFinished    Int      @default(0) @map("books_finished")
  gamesFinished    Int      @default(0) @map("games_finished")
  coursesCompleted Int      @default(0) @map("courses_completed")
  hoursWatched     Int      @default(0) @map("hours_watched")
  hoursPlayed      Int      @default(0) @map("hours_played")
  hoursRead        Int      @default(0) @map("hours_read")
  hoursLearned     Int      @default(0) @map("hours_learned")
  favoriteGenre    String?  @map("favorite_genre")
  favoritePlatform String?  @map("favorite_platform")
  metadata         Json?    @map("metadata")
  createdAt        DateTime @default(now()) @map("created_at")
  user             User     @relation("AnalyticsSnapshotUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, snapshotDate])
  @@index([snapshotDate])
  @@index([createdAt])
  @@map("analytics_snapshots")
}

model DeviceSession {
  id         String   @id @default(uuid()) @map("id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  deviceName String?  @map("device_name")
  deviceType String?  @map("device_type")
  browser    String?  @map("browser")
  os         String?  @map("os")
  ipAddress  String?  @map("ip_address")
  country    String?  @map("country")
  city       String?  @map("city")
  lastSeen   DateTime @default(now()) @map("last_seen")
  expiresAt  DateTime @map("expires_at")
  isCurrent  Boolean  @default(false) @map("is_current")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation("DeviceSessionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastSeen])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("device_sessions")
}

