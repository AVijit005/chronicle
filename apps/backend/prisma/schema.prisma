generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid()) @map("id") @db.Uuid
  email                   String                   @unique @map("email")
  passwordHash            String?                  @map("password_hash")
  name                    String?                  @map("name")
  displayName             String?                  @map("display_name")
  username                String?                  @unique @map("username")
  bio                     String?                  @map("bio")
  location                String?                  @map("location")
  website                 String?                  @map("website")
  timezone                String?                  @default("UTC") @map("timezone")
  language                String?                  @default("en") @map("language")
  dateFormat              String?                  @default("MM/DD/YYYY") @map("date_format")
  themePreference         String?                  @default("system") @map("theme_preference")
  avatar                  String?                  @map("avatar")
  coverImage              String?                  @map("cover_image")
  preferences             Json?                    @map("preferences")
  privacy                 Json?                    @map("privacy")
  role                    UserRole                 @default(USER) @map("role")
  status                  UserStatus               @default(PENDING_VERIFICATION) @map("status")
  emailVerified           Boolean                  @default(false) @map("email_verified")
  lastLoginAt             DateTime?                @map("last_login_at")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  deletedAt               DateTime?                @map("deleted_at")
  activityFeed            ActivityFeed[]           @relation("ActivityFeedUser")
  analyticsSnapshots      AnalyticsSnapshot[]      @relation("AnalyticsSnapshotUser")
  auditLogs               AuditLog[]
  collections             Collection[]             @relation("CollectionUser")
  customLists             CustomList[]             @relation("CustomListUser")
  deviceSessions          DeviceSession[]          @relation("DeviceSessionUser")
  emailVerificationTokens EmailVerificationToken[]
  favoriteQuotes          FavoriteQuote[]          @relation("FavoriteQuoteUser")
  highlights              Highlight[]              @relation("HighlightUser")
  journalEntries          JournalEntry[]           @relation("JournalEntryUser")
  memories                Memory[]                 @relation("MemoryUser")
  notificationPreferences NotificationPreference?  @relation("NotificationPreferenceUser")
  notifications           Notification[]           @relation("NotificationUser")
  oauthAccounts           OAuthAccount[]
  passwordResetTokens     PasswordResetToken[]
  recommendations         Recommendation[]         @relation("RecommendationUser")
  refreshTokens           RefreshToken[]
  savedSearches           SavedSearch[]            @relation("SavedSearchUser")
  searchHistories         SearchHistory[]          @relation("SearchHistoryUser")
  securityEvents          SecurityEvent[]
  sessions                Session[]
  shelves                 Shelf[]                  @relation("ShelfUser")
  timelineEvents          TimelineEvent[]          @relation("TimelineEventUser")
  userAnimes              UserAnime[]
  userAnimeEpisodes       UserAnimeEpisode[]
  userBooks               UserBook[]
  userCourseLessons       UserCourseLesson[]
  userCourseModules       UserCourseModule[]
  userCourses             UserCourse[]
  userGames               UserGame[]
  userMovies              UserMovie[]
  userMusicAlbums         UserMusicAlbum[]
  userMusicTracks         UserMusicTrack[]
  userPodcastEpisodes     UserPodcastEpisode[]
  userPodcasts            UserPodcast[]
  userTags                UserTag[]                @relation("UserTagUser")
  userTvEpisodes          UserTvEpisode[]
  userTvSeasons           UserTvSeason[]
  userTvShows             UserTvShow[]
  wrappedYears            WrappedYear[]            @relation("WrappedYearUser")

  @@map("users")
}

model OAuthAccount {
  id                String        @id @default(uuid()) @map("id") @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  provider          OAuthProvider @map("provider")
  providerAccountId String        @map("provider_account_id")
  accessToken       String?       @map("access_token")
  refreshToken      String?       @map("refresh_token")
  tokenType         String?       @map("token_type")
  scope             String?       @map("scope")
  idToken           String?       @map("id_token")
  expiresAt         DateTime?     @map("expires_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  deletedAt         DateTime?     @map("deleted_at")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Session {
  id        String        @id @default(uuid()) @map("id") @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  token     String        @unique @map("token")
  expiresAt DateTime      @map("expires_at")
  ipAddress String?       @map("ip_address")
  userAgent String?       @map("user_agent")
  status    SessionStatus @default(ACTIVE) @map("status")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([status])
  @@map("sessions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @map("id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @map("id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id         String    @id @default(uuid()) @map("id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  email      String    @map("email")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model AuditLog {
  id            String      @id @default(uuid()) @map("id") @db.Uuid
  userId        String?     @map("user_id") @db.Uuid
  action        AuditAction @map("action")
  entityType    String      @map("entity_type")
  entityId      String?     @map("entity_id")
  previousValue Json?       @map("previous_value")
  newValue      Json?       @map("new_value")
  metadata      Json?       @map("metadata")
  ipAddress     String?     @map("ip_address")
  userAgent     String?     @map("user_agent")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  user          User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SecurityEvent {
  id          String            @id @default(uuid()) @map("id") @db.Uuid
  userId      String?           @map("user_id") @db.Uuid
  eventType   SecurityEventType @map("event_type")
  severity    SecuritySeverity  @map("severity")
  description String?           @map("description")
  metadata    Json?             @map("metadata")
  ipAddress   String?           @map("ip_address")
  userAgent   String?           @map("user_agent")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  user        User?             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([eventType])
  @@index([severity])
  @@index([createdAt])
  @@map("security_events")
}

model Movie {
  id              String           @id @default(uuid()) @map("id") @db.Uuid
  slug            String           @unique @map("slug")
  title           String           @map("title")
  originalTitle   String?          @map("original_title")
  description     String?          @map("description")
  overview        String?          @map("overview")
  posterUrl       String?          @map("poster_url")
  backdropUrl     String?          @map("backdrop_url")
  bannerUrl       String?          @map("banner_url")
  coverImage      String?          @map("cover_image")
  thumbnail       String?          @map("thumbnail")
  releaseDate     DateTime?        @map("release_date")
  releaseYear     Int?             @map("release_year")
  runtime         Int?             @map("runtime")
  duration        Int?             @map("duration")
  language        String?          @map("language")
  country         String?          @map("country")
  genres          String[]         @default([]) @map("genres")
  tags            String[]         @default([]) @map("tags")
  externalIds     Json?            @map("external_ids")
  metadata        Json?            @map("metadata")
  status          ContentStatus    @default(DRAFT) @map("status")
  contentRating   ContentRating?   @map("content_rating")
  releaseStatus   ReleaseStatus?   @map("release_status")
  budget          Decimal?         @map("budget") @db.Decimal(15, 2)
  revenue         Decimal?         @map("revenue") @db.Decimal(15, 2)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  collectionItems CollectionItem[] @relation("CollectionItemMovie")
  customListItems CustomListItem[] @relation("CustomListItemMovie")
  favoriteQuotes  FavoriteQuote[]  @relation("FavoriteQuoteMovie")
  highlights      Highlight[]      @relation("HighlightMovie")
  mediaTags       MediaTag[]       @relation("MediaTagMovie")
  memoryMedia     MemoryMedia[]    @relation("MemoryMediaMovie")
  recommendations Recommendation[] @relation("RecommendationMovie")
  shelfItems      ShelfItem[]      @relation("ShelfItemMovie")
  userMovies      UserMovie[]

  @@index([title])
  @@index([releaseYear])
  @@index([country])
  @@index([contentRating])
  @@index([releaseStatus])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([status, releaseYear])
  @@index([language, country])
  @@map("movies")
}

model TvShow {
  id              String           @id @default(uuid()) @map("id") @db.Uuid
  slug            String           @unique @map("slug")
  title           String           @map("title")
  originalTitle   String?          @map("original_title")
  description     String?          @map("description")
  overview        String?          @map("overview")
  posterUrl       String?          @map("poster_url")
  backdropUrl     String?          @map("backdrop_url")
  bannerUrl       String?          @map("banner_url")
  coverImage      String?          @map("cover_image")
  thumbnail       String?          @map("thumbnail")
  releaseDate     DateTime?        @map("release_date")
  releaseYear     Int?             @map("release_year")
  runtime         Int?             @map("runtime")
  duration        Int?             @map("duration")
  language        String?          @map("language")
  country         String?          @map("country")
  genres          String[]         @default([]) @map("genres")
  tags            String[]         @default([]) @map("tags")
  externalIds     Json?            @map("external_ids")
  metadata        Json?            @map("metadata")
  status          ContentStatus    @default(DRAFT) @map("status")
  contentRating   ContentRating?   @map("content_rating")
  tvShowStatus    TvShowStatus?    @map("tv_show_status")
  totalSeasons    Int?             @default(0) @map("total_seasons")
  totalEpisodes   Int?             @default(0) @map("total_episodes")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  collectionItems CollectionItem[] @relation("CollectionItemTvShow")
  customListItems CustomListItem[] @relation("CustomListItemTvShow")
  favoriteQuotes  FavoriteQuote[]  @relation("FavoriteQuoteTvShow")
  highlights      Highlight[]      @relation("HighlightTvShow")
  mediaTags       MediaTag[]       @relation("MediaTagTvShow")
  memoryMedia     MemoryMedia[]    @relation("MemoryMediaTvShow")
  recommendations Recommendation[] @relation("RecommendationTvShow")
  shelfItems      ShelfItem[]      @relation("ShelfItemTvShow")
  seasons         TvSeason[]
  userTvShows     UserTvShow[]

  @@index([title])
  @@index([releaseYear])
  @@index([country])
  @@index([contentRating])
  @@index([tvShowStatus])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([status, releaseYear])
  @@index([language, country])
  @@map("tv_shows")
}

model TvSeason {
  id            String         @id @default(uuid()) @map("id") @db.Uuid
  tvShowId      String         @map("tv_show_id") @db.Uuid
  slug          String         @unique @map("slug")
  title         String         @map("title")
  originalTitle String?        @map("original_title")
  description   String?        @map("description")
  overview      String?        @map("overview")
  posterUrl     String?        @map("poster_url")
  backdropUrl   String?        @map("backdrop_url")
  bannerUrl     String?        @map("banner_url")
  coverImage    String?        @map("cover_image")
  thumbnail     String?        @map("thumbnail")
  releaseDate   DateTime?      @map("release_date")
  releaseYear   Int?           @map("release_year")
  runtime       Int?           @map("runtime")
  duration      Int?           @map("duration")
  language      String?        @map("language")
  country       String?        @map("country")
  genres        String[]       @default([]) @map("genres")
  tags          String[]       @default([]) @map("tags")
  externalIds   Json?          @map("external_ids")
  metadata      Json?          @map("metadata")
  seasonNumber  Int            @map("season_number")
  status        ContentStatus  @default(DRAFT) @map("status")
  contentRating ContentRating? @map("content_rating")
  totalEpisodes Int?           @default(0) @map("total_episodes")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")
  episodes      TvEpisode[]
  tvShow        TvShow         @relation(fields: [tvShowId], references: [id], onDelete: Cascade)
  userTvSeasons UserTvSeason[]

  @@unique([tvShowId, seasonNumber])
  @@index([tvShowId])
  @@index([title])
  @@index([releaseYear])
  @@index([language])
  @@index([country])
  @@index([contentRating])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([status, releaseYear])
  @@map("tv_seasons")
}

model TvEpisode {
  id             String          @id @default(uuid()) @map("id") @db.Uuid
  tvSeasonId     String          @map("tv_season_id") @db.Uuid
  slug           String          @unique @map("slug")
  title          String          @map("title")
  originalTitle  String?         @map("original_title")
  description    String?         @map("description")
  overview       String?         @map("overview")
  posterUrl      String?         @map("poster_url")
  backdropUrl    String?         @map("backdrop_url")
  bannerUrl      String?         @map("banner_url")
  coverImage     String?         @map("cover_image")
  thumbnail      String?         @map("thumbnail")
  releaseDate    DateTime?       @map("release_date")
  releaseYear    Int?            @map("release_year")
  runtime        Int?            @map("runtime")
  duration       Int?            @map("duration")
  language       String?         @map("language")
  country        String?         @map("country")
  genres         String[]        @default([]) @map("genres")
  tags           String[]        @default([]) @map("tags")
  externalIds    Json?           @map("external_ids")
  metadata       Json?           @map("metadata")
  episodeNumber  Int             @map("episode_number")
  status         ContentStatus   @default(DRAFT) @map("status")
  contentRating  ContentRating?  @map("content_rating")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")
  tvSeason       TvSeason        @relation(fields: [tvSeasonId], references: [id], onDelete: Cascade)
  userTvEpisodes UserTvEpisode[]

  @@unique([tvSeasonId, episodeNumber])
  @@index([tvSeasonId])
  @@index([title])
  @@index([releaseYear])
  @@index([language])
  @@index([country])
  @@index([status])
  @@index([contentRating])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("tv_episodes")
}

model Anime {
  id              String           @id @default(uuid()) @map("id") @db.Uuid
  slug            String           @unique @map("slug")
  title           String           @map("title")
  originalTitle   String?          @map("original_title")
  description     String?          @map("description")
  overview        String?          @map("overview")
  posterUrl       String?          @map("poster_url")
  backdropUrl     String?          @map("backdrop_url")
  bannerUrl       String?          @map("banner_url")
  coverImage      String?          @map("cover_image")
  thumbnail       String?          @map("thumbnail")
  releaseDate     DateTime?        @map("release_date")
  releaseYear     Int?             @map("release_year")
  runtime         Int?             @map("runtime")
  duration        Int?             @map("duration")
  language        String?          @map("language")
  country         String?          @map("country")
  genres          String[]         @default([]) @map("genres")
  tags            String[]         @default([]) @map("tags")
  externalIds     Json?            @map("external_ids")
  metadata        Json?            @map("metadata")
  status          ContentStatus    @default(DRAFT) @map("status")
  contentRating   ContentRating?   @map("content_rating")
  animeStatus     AnimeStatus?     @map("anime_status")
  totalEpisodes   Int?             @default(0) @map("total_episodes")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  episodes        AnimeEpisode[]
  collectionItems CollectionItem[] @relation("CollectionItemAnime")
  customListItems CustomListItem[] @relation("CustomListItemAnime")
  favoriteQuotes  FavoriteQuote[]  @relation("FavoriteQuoteAnime")
  highlights      Highlight[]      @relation("HighlightAnime")
  mediaTags       MediaTag[]       @relation("MediaTagAnime")
  memoryMedia     MemoryMedia[]    @relation("MemoryMediaAnime")
  recommendations Recommendation[] @relation("RecommendationAnime")
  shelfItems      ShelfItem[]      @relation("ShelfItemAnime")
  userAnimes      UserAnime[]

  @@index([title])
  @@index([releaseYear])
  @@index([country])
  @@index([contentRating])
  @@index([animeStatus])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([status, releaseYear])
  @@index([language, country])
  @@map("anime")
}

model AnimeEpisode {
  id                String             @id @default(uuid()) @map("id") @db.Uuid
  animeId           String             @map("anime_id") @db.Uuid
  slug              String             @unique @map("slug")
  title             String             @map("title")
  originalTitle     String?            @map("original_title")
  description       String?            @map("description")
  overview          String?            @map("overview")
  posterUrl         String?            @map("poster_url")
  backdropUrl       String?            @map("backdrop_url")
  bannerUrl         String?            @map("banner_url")
  coverImage        String?            @map("cover_image")
  thumbnail         String?            @map("thumbnail")
  releaseDate       DateTime?          @map("release_date")
  releaseYear       Int?               @map("release_year")
  runtime           Int?               @map("runtime")
  duration          Int?               @map("duration")
  language          String?            @map("language")
  country           String?            @map("country")
  genres            String[]           @default([]) @map("genres")
  tags              String[]           @default([]) @map("tags")
  externalIds       Json?              @map("external_ids")
  metadata          Json?              @map("metadata")
