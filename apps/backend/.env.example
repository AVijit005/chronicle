NODE_ENV=development
PORT=3000

# Email
RESEND_API_KEY=re_123456789
EMAIL_FROM=hello@chronicle.app
API_PREFIX=api

DATABASE_URL=postgresql://chronicle:chronicle@localhost:5432/chronicle?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

BULLMQ_PREFIX=chronicle

SWAGGER_ENABLED=false
CORS_ORIGIN=http://localhost:5173

